{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nissinedu",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
